{
  "name": "flock-energy-api",
  "version": "1.0.0",
  "description": "Production-ready REST API wrapper for the Urja Meter Ops Portal",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "generate:openapi": "node scripts/generateOpenApi.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "flock-energy",
    "urja",
    "smart-meter",
    "rest-api",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.3",
    "cheerio": "^1.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tough-cookie": "^5.0.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
